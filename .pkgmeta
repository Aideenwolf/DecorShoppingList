package-as: DecorShoppingList
enable-nolib-creation: no

ignore: # Files and directories beginning with a dot (such as .git) are automatically ignored, as is the pgkmeta file itself.
    - .vscode/
    - .github/

# Embedded libraries mirrored by embeds.xml

externals:
  libs/Ace3/CallbackHandler-1.0: https://repos.wowace.com/wow/ace3/trunk/CallbackHandler-1.0
  libs/Ace3/AceAddon-3.0: https://repos.wowace.com/wow/ace3/trunk/AceAddon-3.0
  libs/Ace3/AceEvent-3.0: https://repos.wowace.com/wow/ace3/trunk/AceEvent-3.0
  libs/Ace3/AceConsole-3.0: https://repos.wowace.com/wow/ace3/trunk/AceConsole-3.0
  libs/Ace3/AceTimer-3.0: https://repos.wowace.com/wow/ace3/trunk/AceTimer-3.0
  libs/Ace3/AceDB-3.0: https://repos.wowace.com/wow/ace3/trunk/AceDB-3.0
  libs/Ace3/AceLocale-3.0: https://repos.wowace.com/wow/ace3/trunk/AceLocale-3.0

  libs/LibStub: https://repos.wowace.com/wow/libstub/trunk

  libs/LibPeriodicTable-3.1/LibPeriodicTable-3.1: https://repos.curseforge.com/wow/libperiodictable-3-1/trunk/LibPeriodicTable-3.1
  libs/LibPeriodicTable-3.1/LibPeriodicTable-3.1-Tradeskill: https://repos.curseforge.com/wow/libperiodictable-3-1/trunk/LibPeriodicTable-3.1-Tradeskill

  libs/LibDataBroker-1.1: https://repos.wowace.com/wow/libdatabroker-1-1/trunk

  libs/LibSharedMedia-3.0: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk

  libs/LibDBIcon-1.0: https://repos.wowace.com/wow/libdbicon-1-0/trunk
